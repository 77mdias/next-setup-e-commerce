{
  "name": "my-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start:e2e": "E2E_CHECKOUT_MOCK_MODE=true NEXTAUTH_COOKIE_SECURE=false NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 next start -p 3100",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format:check": "node scripts/prettier-changed.js --check",
    "format:write": "node scripts/prettier-changed.js --write",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "clean:next": "node scripts/clean-next-cache.js",
    "postinstall": "prisma generate",
    "backup-images": "node scripts/backup-processed-images.js backup",
    "restore-images": "node scripts/backup-processed-images.js restore",
    "smart-seed": "node scripts/smart-seed.js",
    "reprocess-images": "node scripts/auto-reprocess-images.js",
    "check-images": "node scripts/check-processed-images.js",
    "seed": "prisma db seed",
    "inventory:reservations:cleanup": "ts-node scripts/inventory-reservations-cleanup.ts --apply",
    "inventory:reservations:cleanup:dry-run": "ts-node scripts/inventory-reservations-cleanup.ts",
    "tokens:cleanup-expired": "node scripts/cleanup-expired-auth-tokens.js --apply",
    "e2e:prepare": "node scripts/prepare-e2e-data.js",
    "orders:backfill-user-id": "node scripts/backfill-order-user-id.js",
    "test:e2e": "NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 NEXTAUTH_COOKIE_SECURE=false npm run build && NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 NEXTAUTH_COOKIE_SECURE=false E2E_PREPARE_MAX_ATTEMPTS=6 E2E_PREPARE_RETRY_BASE_MS=2000 npm run e2e:prepare && NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 NEXTAUTH_COOKIE_SECURE=false playwright test --config playwright.config.ts --grep @critical",
    "test:e2e:critical:ci": "NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 NEXTAUTH_COOKIE_SECURE=false E2E_PREPARE_MAX_ATTEMPTS=6 E2E_PREPARE_RETRY_BASE_MS=2000 npm run e2e:prepare && NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3100 NEXTAUTH_URL=http://127.0.0.1:3100 NEXTAUTH_COOKIE_SECURE=false playwright test --config playwright.config.ts --grep @critical",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:security": "vitest run --config vitest.integration.config.ts src/app/api/auth/forgot-password/__tests__/route.integration.test.ts src/app/api/auth/reset-password/__tests__/route.integration.test.ts src/app/api/auth/verify-email/__tests__/route.integration.test.ts src/app/api/auth/__tests__/rate-limit.integration.test.ts src/app/api/remove-bg/__tests__/route.integration.test.ts src/app/api/admin/remove-bg/__tests__/route.integration.test.ts src/app/api/remove-bg/__tests__/shared-rate-limit.integration.test.ts",
    "test:integration:critical": "vitest run --config vitest.integration.config.ts src/app/api/checkout/__tests__/route.integration.test.ts src/app/api/webhooks/stripe/__tests__/route.integration.test.ts \"src/app/api/orders/[orderId]/__tests__/route.integration.test.ts\" \"src/app/api/orders/session/[sessionId]/__tests__/route.integration.test.ts\" src/app/orders/__tests__/page.integration.test.ts src/app/api/admin/dashboard/__tests__/route.integration.test.ts src/app/api/admin/orders/__tests__/route.integration.test.ts \"src/app/api/admin/orders/[orderId]/__tests__/route.integration.test.ts\" src/app/api/admin/products/__tests__/route.integration.test.ts \"src/app/api/admin/products/[productId]/__tests__/route.integration.test.ts\" src/app/api/admin/customers/__tests__/route.integration.test.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:critical": "npm run test:unit"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@stripe/stripe-js": "^7.8.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.1",
    "autoprefixer": "^10.4.21",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "form-data": "^4.0.4",
    "lucide-react": "^0.539.0",
    "neon": "^2.0.0",
    "neonctl": "^2.15.0",
    "next": "15.4.10",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.1",
    "prisma": "^6.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-number-format": "^5.4.4",
    "sass": "^1.90.0",
    "sonner": "^2.0.7",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "vaul": "^1.1.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.11",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.33.0",
    "eslint-config-next": "^15.4.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
