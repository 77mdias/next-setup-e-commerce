# Core database (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my_store?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/my_store?schema=public"

# NextAuth (required)
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-secret"

# OAuth providers (required by current src/lib/auth.ts configuration)
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe checkout (required for checkout/webhooks)
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_WEBHOOK_SECRET_KEY="whsec_your_webhook_secret_here"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Optional: demo automation for order/payment/delivery timeline
# false (default) = disable automation
# true = auto-advance PENDING/PAYMENT_PENDING -> PAID (~2min), then PROCESSING/SHIPPED/DELIVERED
DEMO_ORDER_AUTOMATION_ENABLED="false"
DEMO_ORDER_PAYMENT_CONFIRMED_AFTER_MINUTES="2"
DEMO_ORDER_PROCESSING_AFTER_MINUTES="4"
DEMO_ORDER_SHIPPED_AFTER_MINUTES="6"
DEMO_ORDER_DELIVERED_AFTER_MINUTES="8"

# Email (required for email verification and password reset flows)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-gmail-app-password"

# Optional: only used by image processing scripts
REMOVE_BG_API_KEY="your-remove-bg-api-key"
# Comma-separated host allowlist used by /api/remove-bg and /api/admin/remove-bg
REMOVE_BG_ALLOWED_IMAGE_HOSTS="images.kabum.com.br,m.media-amazon.com,cdn.shopify.com"
# Comma-separated protocol allowlist (without or with colon)
REMOVE_BG_ALLOWED_IMAGE_PROTOCOLS="https"

# Optional: global access mode for route feedback screen (/status)
# Values: maintenance | outage | development | unavailable
# Leave empty for normal operation
APP_ACCESS_MODE=""

# Optional: route prefixes redirected to /status automatically.
# Use comma-separated values. Examples:
# APP_DEVELOPMENT_ROUTES="/ofertas,/beta,/admin/analytics"
# APP_MAINTENANCE_ROUTES="/checkout,/api-legacy"
# APP_UNAVAILABLE_ROUTES="/suporte"
APP_DEVELOPMENT_ROUTES=""
APP_MAINTENANCE_ROUTES=""
APP_UNAVAILABLE_ROUTES=""

# Optional: hardening controls for /api/test-stripe outside development
# Keep disabled by default.
ENABLE_TEST_STRIPE_ENDPOINT="false"
INTERNAL_DEBUG_KEY=""
# Comma-separated IP allowlist, used only when ENABLE_TEST_STRIPE_ENDPOINT=true outside development
TEST_STRIPE_ALLOWED_IPS=""

# Optional: deterministic checkout mode for Playwright E2E (disabled by default)
E2E_CHECKOUT_MOCK_MODE="false"
E2E_USER_EMAIL="e2e.customer@nextstore.local"
E2E_USER_PASSWORD="E2eCheckout#123"
E2E_PRODUCT_QUERY="E2E Checkout Headset"
